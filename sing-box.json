{
  "log": {
    "level": "info"
  },
  "dns": {
    "servers": []
  },
  "outbounds": [
    {
      "type": "block",
      "tag": "PLACEHOLDER_EU_OUTBOUND"
    },
    {
      "type": "block",
      "tag": "PLACEHOLDER_TR_OUTBOUND"
    },
    {
      "type": "block",
      "tag": "PLACEHOLDER_AUTO_VPS_SELECTOR"
    }
  ],
  "route": {
    "rule_set": [
      {
        "tag": "eu-only",
        "type": "local",
        "format": "source",
        "path": "rulesets/eu-only.json"
      },
      {
        "tag": "tr-only",
        "type": "local",
        "format": "source",
        "path": "rulesets/tr-only.json"
      },
      {
        "tag": "auto-vps",
        "type": "local",
        "format": "source",
        "path": "rulesets/auto-vps.json"
      }
    ],
    "rules": [
      {
        "rule_set": "eu-only",
        "outbound": "PLACEHOLDER_EU_OUTBOUND"
      },
      {
        "rule_set": "tr-only",
        "outbound": "PLACEHOLDER_TR_OUTBOUND"
      },
      {
        "rule_set": "auto-vps",
        "outbound": "PLACEHOLDER_AUTO_VPS_SELECTOR"
      }
    ]
